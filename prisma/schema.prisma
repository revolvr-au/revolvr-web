generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model Post {
  id                String         @id @default(uuid())
  userEmail         String         @map("user_Email")
  imageUrl          String
  caption           String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  media_url         String?
  cloudflareVideoId String?
  muxPlaybackId     String?
  postType          PostType       @default(FEED)
  sparkEligible     Boolean        @default(false)
  voltage           Int            @default(0)
  expiresAt         DateTime?
  originalVariants  String[]       @map("original_variants")
  liveViewerCount   Int            @default(0) @map("live_viewer_count")
  liveStreamId  String?   @map("live_stream_id")
  liveStartedAt  DateTime? @map("live_started_at") @db.Timestamptz(6)
liveEndedAt    DateTime? @map("live_ended_at") @db.Timestamptz(6)
ivsPlaybackUrl String?   @map("ivs_playback_url")

  comments   Comment[]      @relation("PostComments")
  likes      Like[]         @relation("PostLikes")
  media      PostMedia[]    @relation("PostMedia")
  saves      SavedPost[]    @relation("PostSaves")
  reposts    Repost[]       @relation("PostReposts")
  reactions  PostReaction[] @relation("PostReactions")
  liveStream MuxLiveStream? @relation("LiveStreamPosts", fields: [liveStreamId], references: [id])

  @@index([createdAt])
  @@index([userEmail], map: "Post_userEmail_idx")
  @@index([sparkEligible, voltage(sort: Desc)], map: "Post_spark_voltage_idx")
  @@schema("public")
}

/// We could not retrieve columns for the underlying table. Either it has none or you are missing rights to see them. Please check your privileges.
// model identities {
// @@ignore
// @@schema("public")
// }

model liveSession {
  id          String   @id @default(uuid())
  creatorName String
  isActive    Boolean  @default(true)
  startedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userEmail String
  createdAt DateTime @default(now())
  post      Post     @relation("PostLikes", fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userEmail])
  @@index([postId])
  @@schema("public")
}

model SavedPost {
  id        String   @id @default(uuid())
  postId    String
  userEmail String
  createdAt DateTime @default(now())
  post      Post     @relation("PostSaves", fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userEmail])
  @@index([userEmail])
  @@index([postId])
  @@schema("public")
}

model Repost {
  id        String   @id @default(uuid())
  postId    String
  userEmail String
  createdAt DateTime @default(now())
  post      Post     @relation("PostReposts", fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userEmail])
  @@index([userEmail])
  @@index([postId])
  @@schema("public")
}

model PostReaction {
  id        String   @id @default(uuid())
  postId    String
  userEmail String
  emoji     String
  createdAt DateTime @default(now())
  post      Post     @relation("PostReactions", fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userEmail, emoji])
  @@index([postId])
  @@index([userEmail])
  @@schema("public")
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  userEmail String
  body      String
  parentId  String?
  createdAt DateTime  @default(now())

  // ── TRANCHE ADDITIONS ──
  voltage           Int       @default(0)
  originalLanguage  String    @default("en")
  tranched          Boolean   @default(false)
  tranchedAt        DateTime?
  quietPeriodEndsAt DateTime?

  parent        Comment?              @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies       Comment[]             @relation("CommentReplies")
  post          Post                  @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)
  voltageEvents CommentVoltageEvent[]
  trancheEvent  TrancheEvent?         @relation("CommentTranche")
  witnesses     TrancheWitness[]
  factChecks    TFCFactCheck[]

  @@index([postId])
  @@index([parentId])
  @@index([tranched, voltage(sort: Desc)])
  @@index([userEmail])
  @@index([originalLanguage])
  @@schema("public")
}

model CommentVoltageEvent {
  id         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId  String
  actorEmail String
  points     Int
  eventType  CommentVoltageEventType
  dedupeKey  String?                 @unique
  metadata   Json?
  createdAt  DateTime                @default(now()) @db.Timestamptz(6)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId, createdAt(sort: Desc)])
  @@index([actorEmail])
  @@map("comment_voltage_events")
  @@schema("public")
}

enum CommentVoltageEventType {
  VOLT_RECEIVED
  REPLY_RECEIVED
  REACTION_RECEIVED
  WITNESS_RECEIVED

  @@schema("public")
}

model TrancheEvent {
  id                      String        @id @default(uuid())
  commentId               String        @unique
  postId                  String
  commentAuthorEmail      String
  postCreatorEmail        String
  breakoutVoltage         Int
  postVoltageAtBreakout   Int
  voltageSharePct         Float
  timeToThresholdMs       Int
  originalLanguage        String        @default("en")
  status                  TrancheStatus @default(ACTIVE)
  sinBinLevel             Int           @default(0)
  sinBinExpiresAt         DateTime?
  struckOutAt             DateTime?
  struckOutReason         String?
  gathId                  String?
  totalWitnesses          Int           @default(0)
  totalReplies            Int           @default(0)
  totalVoltsSinceBreakout Int           @default(0)
  peakVoltage             Int           @default(0)
  isSponsored             Boolean       @default(false)
  sponsorEmail            String?
  sponsorApprovedAt       DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  comment           Comment                   @relation("CommentTranche", fields: [commentId], references: [id])
  witnesses         TrancheWitness[]
  notifications     TrancheNotification[]
  sinBinLogs        TrancheSinBinLog[]
  factChecks        TFCFactCheck[]
  originatorPayouts TrancheOriginatorPayout[]

  @@index([postId])
  @@index([commentAuthorEmail])
  @@index([postCreatorEmail])
  @@index([status, createdAt(sort: Desc)])
  @@index([originalLanguage, status])
  @@index([gathId])
  @@map("tranche_events")
  @@schema("public")
}

enum TrancheStatus {
  ACTIVE
  SIN_BIN
  STRUCK_OUT
  ARCHIVED

  @@schema("public")
}

model TrancheConfig {
  id                   String   @id @default("singleton")
  absoluteVoltageFloor Int      @default(200)
  relativeVoltageShare Float    @default(0.15)
  quietPeriodSeconds   Int      @default(90)
  sinBin1Minutes       Int      @default(10)
  sinBin2Minutes       Int      @default(30)
  maxWitnessesPerUser  Int      @default(1)
  sponsorRevenueShare  Float    @default(0.20)
  creatorRevenueShare  Float    @default(0.10)
  updatedAt            DateTime @updatedAt
  updatedBy            String?

  @@map("tranche_config")
  @@schema("public")
}

model TrancheWitness {
  id               String   @id @default(uuid())
  trancheEventId   String
  commentId        String
  witnessEmail     String
  voltageAtWitness Int
  createdAt        DateTime @default(now())

  trancheEvent TrancheEvent @relation(fields: [trancheEventId], references: [id], onDelete: Cascade)
  comment      Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([trancheEventId, witnessEmail])
  @@index([witnessEmail])
  @@index([trancheEventId])
  @@map("tranche_witnesses")
  @@schema("public")
}

model TrancheNotification {
  id             String                  @id @default(uuid())
  trancheEventId String?
  recipientEmail String
  type           TrancheNotificationType
  isRead         Boolean                 @default(false)
  isPlatformWide Boolean                 @default(false)
  metadata       Json?
  sentAt         DateTime                @default(now())

  trancheEvent TrancheEvent? @relation(fields: [trancheEventId], references: [id], onDelete: Cascade)

  @@index([recipientEmail, isRead])
  @@index([trancheEventId])
  @@map("tranche_notifications")
  @@schema("public")
}

enum TrancheNotificationType {
  BREAKOUT_AUTHOR
  BREAKOUT_CREATOR
  WITNESS_EARLY
  SIN_BIN_1
  SIN_BIN_2
  STRUCK_OUT
  COLLISION_DETECTED
  GATH_SEEDED
  SPONSORED
  TFC_FILED
  TFC_CLEARED
  TFC_APPROVED
  TFC_REJECTED
  ORIGINATOR_PAYOUT

  @@schema("public")
}

model TFCMember {
  id             String    @id @default(uuid())
  userEmail      String    @unique
  status         TFCStatus @default(PENDING)
  languages      String[]  @default(["en"])
  domains        String[]  @default([])
  motivation     String?
  accuracyScore  Float     @default(1.0)
  totalChecks    Int       @default(0)
  correctChecks  Int       @default(0)
  termStartedAt  DateTime?
  termEndsAt     DateTime?
  isProfessional Boolean   @default(false)
  orgName        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  factChecks   TFCFactCheck[]
  contests     TFCContest[]   @relation("TFCMemberContests")
  panelReviews TFCContest[]   @relation("TFCPanelReviews")

  @@index([status])
  @@index([termEndsAt])
  @@map("tfc_members")
  @@schema("public")
}

enum TFCStatus {
  PENDING
  ACTIVE
  EXPIRED
  SUSPENDED
  PROFESSIONAL

  @@schema("public")
}

model TFCFactCheck {
  id             String         @id @default(uuid())
  trancheEventId String
  commentId      String
  checkerEmail   String
  claim          String
  verdict        TFCVerdict
  correction     String?
  sources        String[]       @default([])
  language       String         @default("en")
  status         TFCCheckStatus @default(PENDING)
  sinBinApplied  Int            @default(0)
  contestedAt    DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  trancheEvent TrancheEvent @relation(fields: [trancheEventId], references: [id])
  comment      Comment      @relation(fields: [commentId], references: [id])
  checker      TFCMember    @relation(fields: [checkerEmail], references: [userEmail])
  contest      TFCContest?

  @@index([trancheEventId])
  @@index([checkerEmail])
  @@index([verdict])
  @@map("tfc_fact_checks")
  @@schema("public")
}

enum TFCVerdict {
  TRUE
  FALSE
  MISLEADING
  UNVERIFIABLE
  SATIRE

  @@schema("public")
}

enum TFCCheckStatus {
  PENDING
  ACTIVE
  CONTESTED
  PANEL_REVIEW
  RESOLVED
  OVERTURNED

  @@schema("public")
}

model TFCContest {
  id              String             @id @default(uuid())
  factCheckId     String             @unique
  contestantEmail String
  counterSources  String[]           @default([])
  argument        String
  outcome         TFCContestOutcome?
  panelEmails     String[]           @default([])
  resolvedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  factCheck    TFCFactCheck @relation(fields: [factCheckId], references: [id])
  filer        TFCMember?   @relation("TFCMemberContests", fields: [contestantEmail], references: [userEmail])
  panelMembers TFCMember[]  @relation("TFCPanelReviews")

  @@index([contestantEmail])
  @@map("tfc_contests")
  @@schema("public")
}

enum TFCContestOutcome {
  UPHELD
  REJECTED
  SPLIT

  @@schema("public")
}

model TrancheSinBinLog {
  id             String    @id @default(uuid())
  trancheEventId String
  level          Int
  reason         String
  appliedBy      String
  expiresAt      DateTime?
  liftedAt       DateTime?
  createdAt      DateTime  @default(now())

  trancheEvent TrancheEvent @relation(fields: [trancheEventId], references: [id])

  @@index([trancheEventId])
  @@map("tranche_sin_bin_logs")
  @@schema("public")
}

model TrancheOriginatorPayout {
  id               String           @id @default(uuid())
  trancheEventId   String
  recipientEmail   String
  role             OriginatorRole
  sourceType       OriginatorSource
  grossCents       Int
  recipientCents   Int
  platformCents    Int
  currency         String           @default("AUD")
  status           PayoutStatus     @default(PENDING)
  stripeTransferId String?
  createdAt        DateTime         @default(now())
  settledAt        DateTime?

  trancheEvent TrancheEvent @relation(fields: [trancheEventId], references: [id])

  @@index([recipientEmail])
  @@index([trancheEventId])
  @@index([status])
  @@map("tranche_originator_payouts")
  @@schema("public")
}

enum OriginatorRole {
  COMMENT_AUTHOR
  POST_CREATOR

  @@schema("public")
}

enum OriginatorSource {
  GATH_TICKET
  SPONSORSHIP
  COMMERCE

  @@schema("public")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  SETTLED
  FAILED

  @@schema("public")
}

model TrancheCollision {
  id              String          @id @default(uuid())
  trancheEventIdA String
  trancheEventIdB String
  detectedAt      DateTime        @default(now())
  conflictSummary String?
  status          CollisionStatus @default(ACTIVE)
  resolvedAt      DateTime?
  winnerEventId   String?

  @@unique([trancheEventIdA, trancheEventIdB])
  @@index([trancheEventIdA])
  @@index([trancheEventIdB])
  @@index([status])
  @@map("tranche_collisions")
  @@schema("public")
}

enum CollisionStatus {
  ACTIVE
  RESOLVED
  EXPIRED

  @@schema("public")
}

model PostMedia {
  id        String   @id @default(uuid())
  postId    String
  type      String
  url       String
  order     Int      @map("order")
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  post      Post     @relation("PostMedia", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@schema("public")
}

model RevolvrItem {
  id        String        @id @default(uuid())
  createdAt DateTime      @default(now())
  notes     String?
  status    RevolvrStatus @default(NEW)
  updatedAt DateTime      @updatedAt
  value     Int?
  name      String

  @@schema("public")
}

model Follow {
  id             String   @id @default(uuid())
  followerEmail  String
  followingEmail String
  createdAt      DateTime @default(now())

  @@unique([followerEmail, followingEmail], name: "uniq_follow_pair")
  @@index([followingEmail])
  @@schema("public")
}

model UserCredits {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  email     String   @unique
  boosts    Int      @default(0)
  tips      Int      @default(0)
  spins     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sparks Int @default(0)

  @@schema("public")
}

model CreatorBalance {
  creatorEmail       String   @id
  totalEarnedCents   Int      @default(0)
  availableCents     Int      @default(0)
  updatedAt          DateTime @updatedAt
  taxCountry         String?  @default("AU") @map("tax_country")
  taxId              String?  @map("tax_id")
  taxIdVerified      Boolean? @default(false) @map("tax_id_verified")
  taxReserveCents    Int      @default(0) @map("tax_reserve_cents")
  totalWithheldCents Int      @default(0) @map("total_withheld_cents")

  @@schema("public")
}

model SupportLedger {
  id            String        @id @default(cuid())
  creatorEmail  String
  viewerEmail   String?
  kind          SupportKind
  source        SupportSource
  targetId      String?
  units         Int           @default(1)
  currency      String        @default("AUD")
  grossCents    Int           @default(0)
  creatorCents  Int           @default(0)
  platformCents Int           @default(0)
  createdAt     DateTime      @default(now())

  @@index([creatorEmail])
  @@index([viewerEmail])
  @@index([targetId])
  @@index([creatorEmail], map: "support_ledger_creator_idx")
  @@index([kind], map: "support_ledger_kind_idx")
  @@index([targetId], map: "support_ledger_target_idx")
  @@index([creatorEmail, kind, createdAt(sort: Desc)], map: "supportledger_creator_kind_createdat_idx")
  @@index([kind, createdAt(sort: Desc)], map: "supportledger_kind_createdat_idx")
  @@index([kind, targetId], map: "supportledger_kind_target_idx")
  @@index([targetId, kind], map: "supportledger_target_kind_idx")
  @@index([viewerEmail, kind, targetId], map: "supportledger_viewer_kind_target_idx")
  @@schema("public")
}

model Payment {
  id                    String   @id
  stripeEventId         String   @unique
  stripePaymentIntentId String
  stripeSessionId       String?
  creatorId             String
  sessionId             String?
  type                  String
  amountGross           Int
  amountCreator         Int
  amountPlatform        Int
  currency              String
  status                String
  createdAt             DateTime @default(now())

  @@schema("public")
}

model CreatorPayout {
  id               String   @id @default(uuid())
  creatorId        String
  amount           Int
  stripeTransferId String
  status           String
  createdAt        DateTime @default(now())

  @@schema("public")
}

model StripeCheckoutReceipt {
  id            String   @id @default(cuid())
  sessionId     String   @unique @map("session_id")
  paymentIntent String?  @map("payment_intent")
  eventId       String?  @map("event_id")
  livemode      Boolean  @default(false)
  amountTotal   Int?     @map("amount_total")
  currency      String?
  status        String?
  paymentStatus String?  @map("payment_status")
  customerEmail String?  @map("customer_email")
  metadata      Json?
  raw           Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([paymentIntent])
  @@index([customerEmail])
  @@index([createdAt])
  @@map("stripe_checkout_receipts")
  @@schema("public")
}

model FeedSnapshot {
  id          String   @id @default(uuid())
  viewerEmail String   @map("viewer_email")
  postId      String   @map("post_id")
  rankScore   Float    @default(0) @map("rank_score")
  payload     Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([viewerEmail])
  @@schema("public")
}

