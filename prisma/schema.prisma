generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model Post {
  id        String         @id @default(uuid())
  userEmail String         @map("user_Email")
  imageUrl  String
  caption   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  media_url String?
  comments  Comment[]      @relation("PostComments")
  likes     Like[]         @relation("PostLikes")
  media     PostMedia[]    @relation("PostMedia")
  reactions PostReaction[] @relation("PostReactions")

  @@index([createdAt])
  @@index([userEmail], map: "Post_userEmail_idx")
  @@schema("public")
}

/// We could not retrieve columns for the underlying table. Either it has none or you are missing rights to see them. Please check your privileges.
// model identities {
// @@ignore
// @@schema("public")
// }

model liveSession {
  id          String   @id @default(uuid())
  creatorName String
  isActive    Boolean  @default(true)
  startedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userEmail String
  createdAt DateTime @default(now())
  post      Post     @relation("PostLikes", fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userEmail])
  @@index([postId])
  @@schema("public")
}

model PostReaction {
  id        String   @id @default(uuid())
  postId    String
  userEmail String
  emoji     String
  createdAt DateTime @default(now())
  post      Post     @relation("PostReactions", fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userEmail, emoji])
  @@index([postId])
  @@index([userEmail])
  @@schema("public")
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  userEmail String
  body      String
  parentId  String?
  createdAt DateTime  @default(now())
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   Comment[] @relation("CommentReplies")
  post      Post      @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([parentId])
  @@schema("public")
}

model PostMedia {
  id        String   @id @default(uuid())
  postId    String
  type      String
  url       String
  order     Int      @map("order")
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  post      Post     @relation("PostMedia", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@schema("public")
}

model RevolvrItem {
  id        String        @id @default(uuid())
  createdAt DateTime      @default(now())
  notes     String?
  status    RevolvrStatus @default(NEW)
  updatedAt DateTime      @updatedAt
  value     Int?
  name      String

  @@schema("public")
}

model Follow {
  id             String   @id @default(uuid())
  followerEmail  String
  followingEmail String
  createdAt      DateTime @default(now())

  @@unique([followerEmail, followingEmail], name: "uniq_follow_pair")
  @@index([followingEmail])
  @@schema("public")
}

model UserCredits {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  email     String   @unique
  boosts    Int      @default(0)
  tips      Int      @default(0)
  spins     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model CreatorBalance {
  creatorEmail     String   @id
  totalEarnedCents Int      @default(0)
  availableCents   Int      @default(0)
  updatedAt        DateTime @updatedAt

  @@schema("public")
}

model SupportLedger {
  id            String        @id @default(cuid())
  creatorEmail  String
  viewerEmail   String?
  kind          SupportKind
  source        SupportSource
  targetId      String?
  units         Int           @default(1)
  currency      String        @default("AUD")
  grossCents    Int           @default(0)
  creatorCents  Int           @default(0)
  platformCents Int           @default(0)
  createdAt     DateTime      @default(now())

  @@index([creatorEmail])
  @@index([viewerEmail])
  @@index([targetId])
  @@index([creatorEmail], map: "support_ledger_creator_idx")
  @@index([kind], map: "support_ledger_kind_idx")
  @@index([targetId], map: "support_ledger_target_idx")
  @@index([creatorEmail, kind, createdAt(sort: Desc)], map: "supportledger_creator_kind_createdat_idx")
  @@index([kind, createdAt(sort: Desc)], map: "supportledger_kind_createdat_idx")
  @@index([kind, targetId], map: "supportledger_kind_target_idx")
  @@index([targetId, kind], map: "supportledger_target_kind_idx")
  @@index([viewerEmail, kind, targetId], map: "supportledger_viewer_kind_target_idx")
  @@schema("public")
}

model Payment {
  id                    String   @id
  stripeEventId         String   @unique
  stripePaymentIntentId String
  stripeSessionId       String?
  creatorId             String
  sessionId             String?
  type                  String
  amountGross           Int
  amountCreator         Int
  amountPlatform        Int
  currency              String
  status                String
  createdAt             DateTime @default(now())

  @@schema("public")
}

model CreatorPayout {
  id               String   @id @default(uuid())
  creatorId        String
  amount           Int
  stripeTransferId String
  status           String
  createdAt        DateTime @default(now())

  @@schema("public")
}

model StripeCheckoutReceipt {
  id            String   @id @default(cuid())
  sessionId     String   @unique @map("session_id")
  paymentIntent String?  @map("payment_intent")
  eventId       String?  @map("event_id")
  livemode      Boolean  @default(false)
  amountTotal   Int?     @map("amount_total")
  currency      String?
  status        String?
  paymentStatus String?  @map("payment_status")
  customerEmail String?  @map("customer_email")
  metadata      Json?
  raw           Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([paymentIntent])
  @@index([customerEmail])
  @@index([createdAt])
  @@map("stripe_checkout_receipts")
  @@schema("public")
}

model FeedSnapshot {
  id          String   @id @default(uuid())
  viewerEmail String   @map("viewer_email")
  postId      String   @map("post_id")
  rankScore   Float    @default(0) @map("rank_score")
  payload     Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([viewerEmail])
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model creator_profiles {
  user_id       String   @id @db.Uuid
  email         String   @unique
  status        String   @default("ACTIVE")
  display_name  String?
  handle        String?
  revenue_share Decimal  @default(0.45) @db.Decimal
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  avatar_url    String?
  bio           String?

  @@index([user_id])
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model creators {
  id                       String         @id @db.Uuid
  handle                   String         @unique(map: "creators_handle_unique_idx") @db.Citext
  display_name             String?
  status                   creator_status @default(active)
  created_at               DateTime       @default(now()) @db.Timestamptz(6)
  stripe_account_id        String?
  stripe_onboarding_status String         @default("not_started")
  stripe_charges_enabled   Boolean        @default(false)
  stripe_payouts_enabled   Boolean        @default(false)
  payout_currency          String?

  @@index([status])
  @@index([stripe_account_id])
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model live_chat_messages {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id      String
  user_id      String?  @db.Uuid
  user_email   String?
  display_name String?
  message      String
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  avatar_url   String?

  @@index([room_id, created_at], map: "live_chat_messages_room_created_idx")
  @@schema("public")
}

model live_polls {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  live_id    String   @unique(map: "live_polls_live_unique") @db.Uuid
  option_a   String
  option_b   String
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model paid_reactions {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  context_type String
  context_id   String   @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([context_type, context_id], map: "paid_reactions_context_idx")
  @@index([user_id], map: "paid_reactions_user_idx")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  email        String   @id
  display_name String?
  avatar_url   String?
  bio          String?
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model spinner_spins {
  id         BigInt   @id @default(autoincrement())
  user_email String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  payload    Json?

  @@index([user_email])
  @@schema("public")
}

model CreatorProfile {
  id          String        @id @default(cuid())
  email       String        @unique
  displayName String
  handle      String?       @unique
  payoutShare Int           @default(45)
  status      CreatorStatus @default(ACTIVE)

  // 🔥 VOLTAGE SYSTEM
  voltage       Int                   @default(0)
  voltageEvents CreatorVoltageEvent[]

  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt
  avatarUrl                      String?   @map("avatar_url")
  bio                            String?
  blue_tick_cancel_at_period_end Boolean   @default(false)
  blue_tick_current_period_end   DateTime? @db.Timestamptz(6)
  blue_tick_customer_id          String?
  blue_tick_status               String    @default("inactive")
  blue_tick_sub_id               String?
  creatorTermsAccepted           Boolean   @default(false) @map("creator_terms_accepted")
  creatorTermsAcceptedAt         DateTime? @map("creator_terms_accepted_at") @db.Timestamptz(6)
  creatorTermsVersion            String?   @map("creator_terms_version")
  isVerified                     Boolean   @default(false) @map("is_verified")
  payoutCurrency                 String    @default("aud") @map("payout_currency")
  stripeAccountId                String?   @map("stripe_account_id")
  stripeChargesEnabled           Boolean   @default(false) @map("stripe_charges_enabled")
  stripeCustomerId               String?   @map("stripe_customer_id")
  stripeOnboardingStatus         String    @default("not_started") @map("stripe_onboarding_status")
  stripePayoutsEnabled           Boolean   @default(false) @map("stripe_payouts_enabled")
  stripeSubscriptionId           String?   @unique(map: "creatorprofile_stripe_subscription_id_key") @map("stripe_subscription_id")
  verificationCurrentPeriodEnd   DateTime? @map("verification_current_period_end") @db.Timestamptz(6)
  verificationPriceId            String?   @map("verification_price_id")
  verificationStatus             String    @default("inactive") @map("verification_status")
  verifiedSince                  DateTime? @map("verified_since") @db.Timestamptz(6)

  @@index([blue_tick_sub_id], map: "creatorprofile_blue_tick_sub_id_idx")
  @@map("CreatorProfile")
  @@schema("public")
}

model CreatorVoltageEvent {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorEmail String
  actorEmail   String?
  eventType    VoltageEventType
  points       Int
  targetType   VoltageTargetType?
  targetId     String?
  dedupeKey    String?            @unique
  metadata     Json?
  createdAt    DateTime           @default(now()) @db.Timestamptz(6)

  creator CreatorProfile @relation(fields: [creatorEmail], references: [email], onDelete: Cascade)

  @@index([creatorEmail, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("creator_voltage_events")
  @@schema("public")
}

enum VoltageEventType {
  POST_CREATED
  COMMENT_RECEIVED
  FOLLOW_RECEIVED
  GIFT_RECEIVED
  SHARE_RECEIVED
  LIVE_STARTED
  LIVE_GIFT_RECEIVED

  @@schema("public")
}

enum VoltageTargetType {
  POST
  COMMENT
  FOLLOW
  LIVE_SESSION
  CHECKOUT_SESSION
  SHARE

  @@schema("public")
}

enum RevolvrStatus {
  NEW
  ACTIVE
  WON
  LOST

  @@schema("public")
}

enum CreatorStatus {
  ACTIVE
  DISABLED

  @@schema("public")
}

enum SupportKind {
  TIP
  BOOST
  SPIN
  REACTION

  @@schema("public")
}

enum SupportSource {
  FEED
  LIVE

  @@schema("public")
}

enum creator_status {
  pending
  active
  suspended

  @@schema("public")
}
model PostShare {
  id        String   @id @default(uuid())
  postId    String
  userEmail String?
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userEmail])
  @@schema("public")
}

model PostView {
  id          String   @id @default(uuid())
  postId      String
  userEmail   String?
  watchMs     Int      @default(0)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([postId])
  @@index([userEmail])
  @@schema("public")
}

model UserStatus {
  email     String   @id
  status    String   @default("active")
  reason    String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@schema("public")
}

model StudioConfig {
  id               String   @id @default("singleton")
  voltageWeight    Float    @default(1.0)
  interactionWeight Float   @default(7.0)
  clusterWeight    Float    @default(4.0)
  momentumWeight   Float    @default(5.0)
  momentumEnabled  Boolean  @default(true)
  clusteringEnabled Boolean @default(true)
  feedPaused       Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  updatedBy        String?

  @@schema("public")
}

model Broadcast {
  id          String   @id @default(uuid())
  subject     String
  body        String
  sentBy      String
  targetType  String   @default("all")
  targetValue String?
  sentAt      DateTime @default(now())

  @@schema("public")
}
// ── STUDIO ACCESS CONTROL ──
model StudioUser {
  id        String      @id @default(uuid())
  email     String      @unique
  role      StudioRole  @default(SUPPORT)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  createdBy String?
  lastLogin DateTime?

  auditLogs StudioAuditLog[]

  @@index([email])
  @@index([role])
  @@schema("public")
}

model StudioAuditLog {
  id          String     @id @default(uuid())
  studioUser  StudioUser @relation(fields: [actorEmail], references: [email])
  actorEmail  String
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime   @default(now())

  @@index([actorEmail])
  @@index([createdAt])
  @@schema("public")
}

// ── ANALYTICS EVENTS ──
model AnalyticsEvent {
  id          String   @id @default(uuid())
  version     Int      @default(1)
  surface     String   // "feed" | "profile" | "live" | "tranche" | "create"
  eventName   String   // "post_view" | "post_like" | "post_share" | "comment" etc
  userEmail   String?
  sessionId   String?
  postId      String?
  creatorEmail String?
  properties  Json?
  createdAt   DateTime @default(now())

  @@index([eventName, createdAt])
  @@index([userEmail, createdAt])
  @@index([postId, createdAt])
  @@index([surface, createdAt])
  @@schema("public")
}

// ── CREATOR HEALTH SCORE ──
model CreatorHealthScore {
  email              String   @id
  postingConsistency Float    @default(0)
  responseRate       Float    @default(0)
  engagementVelocity Float    @default(0)
  followerGrowthRate Float    @default(0)
  churnRisk          Float    @default(0)
  overallScore       Float    @default(0)
  calculatedAt       DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@schema("public")
}

// ── USER SESSIONS ──
model UserSession {
  id          String   @id @default(uuid())
  userEmail   String
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  durationMs  Int?
  postsViewed Int      @default(0)
  platform    String?  // "web" | "ios" | "android"
  country     String?

  @@index([userEmail])
  @@index([startedAt])
  @@schema("public")
}

enum StudioRole {
  ADMIN
  MODERATOR
  SUPPORT

  @@schema("public")
}